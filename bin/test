#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$ROOT_DIR"

exec docker compose run --rm -T app sh -lc '
  if [ ! -f .env ]; then cp .env.example .env; fi
  if [ ! -f vendor/autoload.php ]; then composer install; fi
  php artisan config:clear --ansi
  ./vendor/bin/pest "$@"
' sh "$@"
